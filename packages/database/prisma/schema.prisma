// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}


datasource db {
  provider = "postgresql"
}

enum AssetType {
  STOCK
  CRYPTO
  ETF
}

enum Exchange {
  NASDAQ
  NYSE
  NSE
  BSE
  BINANCE
  COINBASE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  webhookUrl   String?  @map("webhook_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  watchlistEntries WatchlistEntry[]

  @@map("users")
}

model Asset {
  id        String    @id @default(uuid())
  symbol    String
  exchange  Exchange
  name      String
  assetType AssetType @map("asset_type")
  createdAt DateTime @default(now()) @map("created_at")

  watchlistEntries WatchlistEntry[]
  priceSnapshots   PriceSnapshot[]
  missedFetches    MissedFetch[]

  @@unique([symbol, exchange])
  @@map("assets")
}

model WatchlistEntry {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  assetId   String   @map("asset_id")
  smaPeriod Int      @default(20) @map("sma_period")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset  Asset   @relation(fields: [assetId], references: [id])
  alerts Alert[]

  @@unique([userId, assetId])
  @@map("watchlist_entries")
}

model PriceSnapshot {
  id        String   @id @default(uuid())
  assetId   String   @map("asset_id")
  price     Decimal  @db.Decimal(18, 8)
  fetchedAt DateTime @default(now()) @map("fetched_at")

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([assetId, fetchedAt(sort: Desc)])
  @@map("price_snapshots")
}

model Alert {
  id               String    @id @default(uuid())
  watchlistEntryId String    @map("watchlist_entry_id")
  triggeredPrice   Decimal   @map("triggered_price") @db.Decimal(18, 8)
  smaValue         Decimal   @map("sma_value") @db.Decimal(18, 8)
  delivered        Boolean   @default(false)
  deliveredAt      DateTime? @map("delivered_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  watchlistEntry WatchlistEntry @relation(fields: [watchlistEntryId], references: [id])

  @@map("alerts")
}

model MissedFetch {
  id        String   @id @default(uuid())
  assetId   String   @map("asset_id")
  provider  String   @default("yfinance")
  errorMsg  String?  @map("error_msg")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([assetId, resolved])
  @@index([resolved, createdAt(sort: Desc)])

  @@map("missed_fetches")
}
