{
  "name": "avgdown",
  "private": true,
  "scripts": {
    "build": "bun --env-file=.env.local turbo run build",
    "dev": "bun --env-file=.env.local turbo run dev",
    "lint": "bun --env-file=.env.local turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "bun --env-file=.env.local turbo run check-types",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "bun --env-file=.env.local turbo run db:generate",
    "db:migrate": "bun --env-file=.env.local turbo run db:migrate",
    "db:deploy": "bun --env-file=.env.local turbo run db:deploy"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
